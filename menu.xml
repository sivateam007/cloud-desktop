<?xml version="1.0" encoding="UTF-8"?>
<openbox_menu>
  <menu id="root-menu" label="Applications">
    <item label="Terminal">
      <action name="Execute"><execute>/usr/bin/xterm</execute></action>
    </item>
    <item label="Firefox">
      <action name="Execute"><execute>/usr/bin/firefox</execute></action>
    </item>
    <item label="File Manager">
      <action name="Execute"><execute>/usr/bin/pcmanfm</execute></action>
    </item>
    <separator/>
    <menu id="office" label="Office">
      <item label="Writer (Word)">
        <action name="Execute"><execute>/usr/bin/libreoffice --writer</execute></action>
      </item>
      <item label="Calc (Excel)">
        <action name="Execute"><execute>/usr/bin/libreoffice --calc</execute></action>
      </item>
      <item label="Impress (PPT)">
        <action name="Execute"><execute>/usr/bin/libreoffice --impress</execute></action>
      </item>
    </menu>
    <separator/>
    <item label="Install Extra Apps">
      <action name="Execute"><execute>/usr/bin/xterm -e /home/user/Desktop/install-extra.sh</execute></action>
    </item>
    <item label="Setup Cloud Storage">
      <action name="Execute"><execute>/usr/bin/xterm -e "rclone config; echo Done; read"</execute></action>
    </item>
    <separator/>
    <item label="Refresh">
      <action name="Reconfigure"/>
    </item>
    <item label="Log Out">
      <action name="Exit"/>
    </item>
  </menu>
</openbox_menu>
